# Candace Telegram bridge — copy to .env and fill in. NEVER commit the real .env.

# From https://my.telegram.org -> API development tools (for the Candace account)
TG_API_ID=000000
TG_API_HASH=your_api_hash_here

# String session for the Candace account. Mint once with: python3 login.py
# This is FULL ACCESS to the account — treat like a password, keep it secret.
TG_SESSION=your_string_session_here

# The n8n Telegram webhook (the workflow's Webhook node path).
N8N_WEBHOOK_URL=https://automations.vedametric.com.au/webhook/candace-telegram-async

# Shared secret: must match the X-Bridge-Secret header n8n sends on /send,
# and is also sent on the inbound POST so n8n can verify the bridge.
BRIDGE_SECRET=choose_a_long_random_string

# Where the /send endpoint listens (n8n calls this). Keep on localhost if n8n is
# on the same box; otherwise bind appropriately and lock it down.
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8081

# Optional backstop: max messages the account will send per day (0 = no cap).
SAFETY_DAILY_CAP=0
