      "parameters": {
        "jsCode": "var a = $json; var fan = Array.isArray(a) ? (a[0]||{}) : (a||{});\nvar body = ($('Webhook: send').first().json.body) || $('Webhook: send').first().json || {};\nvar text = (body.text || '').toString();\nif (!fan.id) throw new Error('fan not found');\nif (!text.trim()) throw new Error('empty text');\nreturn [{ json: { fan_id: fan.id, bot_id: fan.bot_id, platform: fan.platform, subscriber_id: fan.manychat_id, text: text } }];"
