      "parameters": {
        "jsCode": "var evs = $json; if (!Array.isArray(evs)) evs = evs ? [evs] : [];\nvar route = null;\nfor (var i=0;i<evs.length;i++){ var p=(evs[i]&&evs[i].payload)||{}; if(p.chat_id&&p.business_connection_id){ route={chat_id:p.chat_id, business_connection_id:p.business_connection_id}; break; } }\nif(!route) throw new Error('no telegram route on record yet — this fan must send one more message so the bot captures chat_id + business_connection_id');\nreturn [{ json: route }];"
