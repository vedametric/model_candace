      "parameters": {
        "method": "GET",
        "url": "={{ 'https://vvnefkexzhfgvuusavvl.supabase.co/rest/v1/messages?fan_id=eq.' + $('DB: fan').first().json.id + '&select=role,content&order=created_at.desc&limit=12' }}",
        "options": {},
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi"
