        "jsCode": "const b=($json.body&&typeof $json.body==='object')?$json.body:$json;\nconst fan_id=parseInt(b.fan_id||b.id,10);\nif(!fan_id) return [];\nreturn [{ json: { fan_id: fan_id } }];"
