      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "options": {},
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { model: $json.model, temperature: 1, max_tokens: 160, frequency_penalty: 0.5, presence_penalty: 0.4, messages: $json.messages } }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBearerAuth"
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        100,
        0
      ],
      "id": "AI000000-re01-4001-8001-000000000001",
      "name": "AI"
    },
    {
      "parameters": {
        "jsCode": "const d=$json||{};\nlet reply='';\ntry{ reply=(d.choices&&d.choices[0]&&d.choices[0].message&&d.choices[0].message.content)?d.choices[0].message.content:''; }catch(e){reply='';}\nreply=(reply||'').trim();\nconst dq=String.fromCharCode(34);\nif(reply.length>1&&reply.charAt(0)===dq&&reply.charAt(reply.length-1)===dq){reply=reply.slice(1,-1).trim();}\nconst allowed=['\\u{1F60F}','\\u{1F92D}','\\u{1F90D}','\\u{1F440}'];\nlet ec=0;\nreply=reply.replace(/\\p{Extended_Pictographic}/gu,function(m){if(allowed.indexOf(m)===-1)return '';ec++;return ec>1?'':m;});\nreply=reply.replace(/[\\u{FE0F}\\u{200D}]/gu,'');\nreply=reply.replace(/\\s*[\\u2014\\u2013]\\s*/g,' ').replace(/\\s+-\\s+/g,' ');\nreply=reply.toLowerCase().replace(/[ \\t]{2,}/g,' ').trim();\nif(!reply)reply='hey you';\nconst b=$('Build').first().json||{};\nreturn [{ json: { reply: reply, fan_id: b.fan_id, bot_id: b.bot_id, platform: b.platform, chat_id: b.chat_id, business_connection_id: b.business_connection_id, manychat_id: b.manychat_id } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        300,
