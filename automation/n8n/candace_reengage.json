    {
      "parameters": {
        "jsCode": "const fan=$('DB: fan').first().json||{};\nconst bot=fan.bots||{};\nconst brain=(bot.system_prompt&&bot.system_prompt.length>50)?bot.system_prompt:'you are candace, a flirty 21yo from columbus ohio. all lowercase, short, no dashes, you are the prize.';\nconst model=(bot.model&&bot.model.length)?bot.model:'gpt-4o';\nlet rec=[]; const ra=$('DB: recent').all(); if(ra.length===1&&Array.isArray(ra[0].json))rec=ra[0].json; else rec=ra.map(i=>i.json);\nconst messages=[{role:'system',content:brain}];\nif(fan.summary&&fan.summary.length)messages.push({role:'system',content:'your private read on him, who he is and where things stand, use it: '+fan.summary});\nfor(const t of rec.slice().reverse()){ if(t&&t.role&&t.content)messages.push({role:t.role,content:t.content}); }\nmessages.push({role:'system',content:'RE-ENGAGE: the conversation has gone quiet. you are reaching out FIRST to revive it, like texting a guy you have not heard from in a bit. send ONE short, natural, on-brand opener that makes him want to reply. use something you remember about him if it fits. warm and a little playful but still the prize, never needy, never desperate, never guilt-trip him for going quiet. reply with only the message.'});\nconst m=fan.metadata||{};\nreturn [{ json: { messages: messages, model: model, fan_id: fan.id, bot_id: fan.bot_id, platform: fan.platform, chat_id: m.chat_id||'', business_connection_id: m.business_connection_id||'', manychat_id: m.manychat_id||'' } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -100,
        0
      ],
