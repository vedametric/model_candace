# Copy to .env on the server (chmod 600). NEVER commit the real .env.
PORT=8787
HOST=127.0.0.1

# Supabase REST base (project URL or full /rest/v1 — both accepted)
SUPABASE_URL=https://vvnefkexzhfgvuusavvl.supabase.co/rest/v1
# service_role key (full DB; RLS is enabled so this is required for live data).
# Get it from Supabase -> Project Settings -> API -> service_role.
SUPABASE_SERVICE_KEY=

# Where per-account content folders live (each a clone of the master repo).
ACCOUNTS_ROOT=/opt/accounts

# "Run worker now" button — fires the content Routine on demand.
ROUTINE_FIRE_URL=https://api.anthropic.com/v1/claude_code/routines/trig_01QWC5YuWeSv8S369PLpBY8p/fire
ROUTINE_FIRE_TOKEN=   # Anthropic Routine token (sk-ant-oat01-…) — server-side only

# Optional: persist persona-doc edits back to git on save.
# DASHBOARD_GIT_TOKEN=ghp_xxx
# DASHBOARD_GIT_REMOTE=github.com/vedametric/model_candace
# DASHBOARD_GIT_AUTHOR=admin-dashboard
# DASHBOARD_GIT_EMAIL=dashboard@vedametric
